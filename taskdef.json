{
    "family": "2048-task",
    "networkMode": "awsvpc",
    "requiresCompatibilities": ["FARGATE"],
    "cpu": "256",
    "memory": "512",
    "executionRoleArn": "arn:aws:iam::886821350656:role/ecsTaskExecutionRole",
    "containerDefinitions": [
      {
        "name": "2048-container",
        "image": "<IMAGE1_NAME>",
        "portMappings": [
          {
            "containerPort": 80,
            "protocol": "tcp"
          }
        ],
        "essential": true,
        "logConfiguration": {
          "logDriver": "awslogs",
          "options": {
            "awslogs-group": "/ecs/2048-task",
            "awslogs-region": "eu-north-1",
            "awslogs-stream-prefix": "ecs"
          }
        }
      }
    ]
  }